# DriverOS Environment Variables
# Copy this to .env.local for local development

# ── App ────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:4005

# ── Data Backend ───────────────────────────────────────────────────
# "local" = localStorage (demo), "supabase" = production Supabase
NEXT_PUBLIC_DATA_BACKEND=local
NEXT_PUBLIC_DEMO_MODE=true

# ── Supabase ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI (Claude) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Database (Docker direct, not needed if using Supabase hosted) ─
POSTGRES_USER=driveros
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=driveros
POSTGRES_PORT=5432
DATABASE_URL=postgresql://driveros:change-me-in-production@localhost:5432/driveros

# ── Redis ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ── Stripe (Payments) ─────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Docker Ports ───────────────────────────────────────────────────
APP_PORT=4005
